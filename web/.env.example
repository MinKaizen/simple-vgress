# Authentication
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_SECRET=generate-a-secure-secret-here
NEXTAUTH_URL=http://localhost:3000

# Domain restriction (comma-separated list of allowed email domains)
ALLOWED_EMAIL_DOMAINS=dashdot.com.au

# Admin user email (first admin, can manage settings)
ADMIN_EMAIL=marketing@dashdot.com.au

# Zapier webhook for notifications
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-webhook-id

# Data directory (defaults to ./data if not set)
DATA_DIR=./data
