# Authentication
# Admin credentials - these will be used to create the admin user on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=generate-a-secure-secret-here
NEXTAUTH_URL=http://localhost:3000

# Zapier webhook for notifications
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-webhook-id

# Data directory (defaults to ./data if not set)
DATA_DIR=./data
